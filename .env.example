# Neon Postgres connection string.
# Format: postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
DATABASE_URL=""

# Auth.js v5 JWT signing secret.
# Generate with: openssl rand -base64 32  (or: npx auth secret)
AUTH_SECRET=""

# Optional in dev (Auth.js auto-detects), required in production.
AUTH_URL=""

# Optional. Without it, AI semantic search falls back to empty results
# (the basic text-search mode is unaffected).
OPENAI_API_KEY=""
